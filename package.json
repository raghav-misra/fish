{
  "name": "fish",
  "version": "0.1.0",
  "private": true,
  "description": "Fish - online multiplayer card game with live video/voice chat",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @fish/web dev",
    "dev:server": "pnpm --filter @fish/server dev",
    "build:shared": "pnpm --filter @fish/shared build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}

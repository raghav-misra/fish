{
  "name": "fish",
  "version": "0.1.0",
  "private": true,
  "description": "Fish - online multiplayer card game with live video/voice chat",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @fish/web dev",
    "dev:server": "pnpm --filter @fish/server dev",
    "build:shared": "pnpm --filter @fish/shared build",
    "admin": "pnpm --filter @fish/server admin",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint apps/server/src apps/web/src packages/shared/src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.60.1"
  }
}

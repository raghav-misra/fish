# Server config
PORT=3000
HOST=0.0.0.0

# Comma-separated list of allowed browser origins (your Vercel/Netlify URL + local dev).
# Example: https://fish.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Secret for the /admin testing API. Always set in shared/prod deployments.
ADMIN_TOKEN=dev-admin-token

# Optional site-wide access key. When set, clients must enter this key to connect.
# Leave empty or unset to disable the gate.
GAME_KEY=

# Redis connection URL for room persistence.
REDIS_URL=redis://localhost:6379
